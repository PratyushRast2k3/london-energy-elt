# ============ Snowflake ============
# ACCOUNT = the account identifier, e.g. abcd-xy12345  (see setup guide)
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_ROLE=ACCOUNTADMIN
SNOWFLAKE_WAREHOUSE=ENERGY_WH
SNOWFLAKE_DATABASE=ENERGY
SNOWFLAKE_SCHEMA=RAW

# ============ Supabase (Postgres) ============
# From Supabase: Project Settings -> Database -> Connection info
SUPABASE_HOST=
SUPABASE_PORT=5432
SUPABASE_DB=postgres
SUPABASE_USER=postgres
SUPABASE_PASSWORD=

# ============ Kaggle ============
# Easiest: place kaggle.json in ~/.kaggle/ and leave these blank.
# Or paste the two values from kaggle.json here:
KAGGLE_USERNAME=
KAGGLE_KEY=
